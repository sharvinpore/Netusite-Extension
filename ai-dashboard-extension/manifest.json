{
    "manifest_version": 3,
    "name": "AI Page Dashboard",
    "version": "1.0",
  
    "permissions": [
      "activeTab",
      "scripting",
      "storage"
    ],
  
    "host_permissions": [
      "https://*.netsuite.com/*",
      "<all_urls>"
    ],
  
    "action": {
      "default_popup": "index.html"
    },
  
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    }
  }